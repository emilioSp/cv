<section id="contact" class="section">
  <div class="cv-container">

    <div class="flex items-center gap-3 mb-[52px]">
      <span class="accent-rule"></span>
      <span class="font-mono text-[14px] tracking-[0.14em] uppercase text-accent">CONTACT</span>
    </div>

    <div class="grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-4 max-w-[760px]">

      <a href="mailto:{{ site.links.email }}" class="hud hud-sm p-5 px-6 no-underline block">
        <div class="font-mono text-[10px] tracking-[0.12em] uppercase text-[#888] mb-2">EMAIL</div>
        <div class="text-[16px] text-[#e4e4e4] tracking-[0.02em]">{{ site.links.email }}</div>
      </a>

      <a href="{{ site.links.linkedin }}" target="_blank" class="hud hud-sm p-5 px-6 no-underline block">
        <div class="font-mono text-[10px] tracking-[0.12em] uppercase text-[#888] mb-2">LINKEDIN</div>
        <div class="text-[16px] text-[#e4e4e4] tracking-[0.02em]">/in/emilio-spatola</div>
      </a>

      <a href="{{ site.links.github }}" target="_blank" class="hud hud-sm p-5 px-6 no-underline block">
        <div class="font-mono text-[10px] tracking-[0.12em] uppercase text-[#888] mb-2">GITHUB</div>
        <div class="text-[16px] text-[#e4e4e4] tracking-[0.02em]">github.com/emilioSp</div>
      </a>

    </div>
  </div>
</section>
