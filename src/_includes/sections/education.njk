<section id="education" class="section">
  <div class="cv-container">

    <div class="flex items-center gap-3 mb-[52px]">
      <span class="accent-rule"></span>
      <span class="font-mono text-[14px] tracking-[0.14em] uppercase text-accent">EDUCATION &amp; PATENTS</span>
    </div>

    <div class="grid grid-cols-[repeat(auto-fit,minmax(min(260px,100%),1fr))] gap-5">

      <!-- Degrees -->
      <div class="hud py-[26px] px-7">
        <div class="hud-card-header">DEGREES</div>
        {% for deg in education.degrees %}
        <div class="{% if not loop.last %}mb-[22px] pb-[22px] border-b border-[rgba(255,255,255,0.04)]{% endif %}">
          <div class="grid grid-cols-[1fr_auto] items-start gap-3 mb-1">
            <div class="text-[16px] font-bold tracking-[0.03em]">{{ deg.level }}</div>
            <span class="font-mono text-[12px] text-[#888] tracking-[0.08em] whitespace-nowrap">{{ deg.years }}</span>
          </div>
          <div class="text-[15px] text-accent tracking-[0.04em] mb-1">{{ deg.field }}</div>
          <div class="text-[14px] text-[#888] mb-1">{{ deg.school }}</div>
          <div class="text-[14px] text-[#888] leading-[1.5] italic">{{ deg.note }}</div>
        </div>
        {% endfor %}
      </div>

      <!-- Patents + Certs -->
      <div class="hud py-[26px] px-7">
        <div class="hud-card-header">PATENTS</div>
        {% for patent in education.patents %}
        <div class="flex gap-[10px] py-[9px]{% if not loop.last %} border-b border-[rgba(255,255,255,0.04)]{% endif %}">
          <span class="text-accent text-[7px] mt-[6px] shrink-0">&#9670;</span>
          {% if patent.href %}
          <a href="{{ patent.href }}" target="_blank"
             class="text-[15px] text-accent leading-[1.5] no-underline transition-opacity duration-200 hover:opacity-70">
            {{ patent.label }} ↗
          </a>
          {% else %}
          <span class="text-[15px] text-[#999] leading-[1.5]">{{ patent.label }}</span>
          {% endif %}
        </div>
        {% endfor %}

        <div class="font-mono text-[14px] tracking-[0.14em] uppercase text-accent mt-6 pt-5 mb-4 border-t border-[#2a2a2a]">LANGUAGES</div>
        <div class="flex gap-[10px] py-[7px] border-b border-[rgba(255,255,255,0.03)]">
                  <span class="text-[#888] text-[7px] mt-[6px] shrink-0">&#9670;</span>
                  <a href="https://cert.efset.org/PVgG7U" target="_blank"
                     class="text-[15px] text-accent leading-[1.5] no-underline transition-opacity duration-200 hover:opacity-70">
                    EF SET English Certificate — C2 Proficient ↗
                  </a>exit
                </div>

        <div class="flex gap-[10px] py-[7px] border-b border-[rgba(255,255,255,0.03)]">
                          <span class="text-[#888] text-[7px] mt-[6px] shrink-0">&#9670;</span>
                          Italian — Native Proficiency
                        </div>

      </div>

    </div>
  </div>
</section>
