{
  "name": "cv",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tailwindcss -i src/css/styles.css -o _site/css/styles.css && concurrently \"eleventy --serve\" \"tailwindcss -i src/css/styles.css -o _site/css/styles.css --watch\"",
    "build": "tailwindcss -i src/css/styles.css -o _site/css/styles.css --minify && eleventy"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.0.0",
    "concurrently": "9.1.2",
    "tailwindcss": "3.4.17"
  }
}
